# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env)
# สร้างค่าสุ่ม: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=เปลี่ยนเป็นค่าสุ่มยาวๆ
PORT=3000

# รหัสลับสำหรับสมัครเป็น "ครู/ผู้บริหาร/แอดมิน" (student/parent ไม่ต้องใช้)
# แจกรหัสนี้ให้เฉพาะครู/ผู้ดูแล
STAFF_SIGNUP_CODE=เปลี่ยนเป็นรหัสลับของคุณ

# --- ตัวเลือกสำหรับ production / deploy (ไม่ใส่ก็ได้ตอน dev) ---
# NODE_ENV=production
# DB_PATH=/var/data/absence.db          # ชี้ไป persistent disk
# UPLOAD_DIR=/var/data/uploads          # ชี้ไป persistent disk

# --- อีเมลจริง (ไม่ใส่ = อีเมลจำลอง log ลง console) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password
# MAIL_FROM=ระบบยื่นใบลา <you@gmail.com>
