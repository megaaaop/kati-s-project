# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env)
# สร้างค่าสุ่ม: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=เปลี่ยนเป็นค่าสุ่มยาวๆ

# รหัสลับสำหรับสมัครครู/ผู้บริหาร/แอดมิน (จำเป็น — ไม่ใส่แอปจะไม่บูต)
STAFF_SIGNUP_CODE=เปลี่ยนเป็นรหัสลับของคุณ

# --- ฐานข้อมูล Postgres (Supabase) ---
# ถ้าไม่ใส่ → ใช้ pglite (Postgres in-memory) สำหรับ dev/test (ข้อมูลไม่ถาวร)
# prod: ใช้ connection string แบบ "Connection pooling / Transaction" ของ Supabase (พอร์ต 6543)
# DATABASE_URL=postgresql://postgres.xxxxx:[DB-PASSWORD]@aws-0-xxxx.pooler.supabase.com:6543/postgres
# (ทางเลือก) ตรวจใบรับรอง TLS เต็มรูปแบบ: ใส่เนื้อหา CA cert ของ Supabase
# PG_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# --- Supabase Storage (ไฟล์แนบ) ---
# ถ้าไม่ใส่ → dev เก็บไฟล์ในเครื่อง (uploads/) , test เก็บในหน่วยความจำ
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_KEY=service_role key (ลับมาก! อย่าเปิดเผย)
# SUPABASE_BUCKET=attachments

# --- อีเมลจริง (ไม่ใส่ = อีเมลจำลอง log ลง console) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password
# MAIL_FROM=ระบบยื่นใบลา <you@gmail.com>
